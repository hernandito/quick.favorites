<FILE Run="/bin/bash">
<INLINE>
<![CDATA[
NAME="quick.favorites"
CONF="/boot/config/plugins/$NAME"

# 1. Create config folder & defaults
mkdir -p $CONF
if [ ! -f "$CONF/appearance.json" ]; then
  echo '{"menu_title":"Quick Favorites","icon_size":"32","bg_color":"#1c1c1c","header_color":"#ffca28","header_line":"#333333","section_title_color":"#888888","section_border_color":"#333333","icon_color":"#e0e0e0","label_color":"#cccccc","grid_columns":"4","menu_width":"480","show_header":"yes","hover_color":"#333333"}' > "$CONF/appearance.json"
fi
if [ ! -f "$CONF/favorites.json" ]; then
  echo '{"/Settings/QuickFavorites":{"category":"General","label":"Quick Fav Settings","icon":"fa-star","action":"_self"}}' > "$CONF/favorites.json"
fi
touch "$CONF/custom.css"
touch "$CONF/user_notes.txt"

# 2. INJECT GLOBAL HOOK INTO UNRAID TEMPLATE
# Remove old entries first to prevent duplicates
sed -i '/quick.favorites\/include.php/d' /usr/local/emhttp/plugins/dynamix/template.php
# BULLETPROOF INJECTION: Append to the very end of the template file
echo '<?php include "/usr/local/emhttp/plugins/quick.favorites/include.php"; ?>' >> /usr/local/emhttp/plugins/dynamix/template.php

# 3. Set Permissions
chmod -R 755 /usr/local/emhttp/plugins/$NAME

echo "----------------------------------------------------"
echo "✅ Quick Favorites has been installed and injected."
echo "----------------------------------------------------"
]]>
</INLINE>
</FILE>

<FILE Run="/bin/bash" Method="remove">
<INLINE>
<![CDATA[
NAME="quick.favorites"

# Remove the global hook from Unraid's template
sed -i '/quick.favorites\/include.php/d' /usr/local/emhttp/plugins/dynamix/template.php

# Remove the plugin web files
rm -rf /usr/local/emhttp/plugins/$NAME

echo "----------------------------------------------------"
echo "✅ Quick Favorites has been completely uninstalled."
echo "----------------------------------------------------"
]]>
</INLINE>
</FILE>
</PLUGIN>
