    .drag-handle:active { cursor: grabbing; }
    
    .preview-wrapper { 
        width: 32px; height: 32px; 
        display: flex; align-items: center; justify-content: center; 
        background: transparent; border: none;
        flex-shrink: 0;
    }
    .preview-wrapper i { color: #777; font-size: 32px; }
    .preview-wrapper img { max-width: 32px; max-height: 32px; }
    
    .qf-btn-scan { padding: 0 6px; height: 30px; font-size: 11px; cursor: pointer; }
    .qf-btn-remove { width: 30px; height: 30px; padding: 0; color: #ff4444; text-align: center; cursor: pointer; border: none; background: none; }

    /* Updated UI Classes */
    .qf-guide-block {
        border-radius: 8px;
        padding: 20px;
        box-sizing: border-box;
        border: 1px solid #b5b5b5;
        border-left: 8px solid #a8a8a9;
		padding-top: 15px;
    }
    .qf-notes-area {
        width: 100%;
        box-sizing: border-box;
        min-height: 250px;
        flex-grow: 1; /* This forces it to stretch and fill the remaining height */
        border: 1px solid rgba(128, 128, 128, 0.4);
        border-radius: 8px;
        padding: 10px;
        background: transparent;
        color: inherit;
        font-family: monospace;
        resize: vertical;
    }
	
	code {
		font-family: monospace;  
		background-color: #f4f4f4;  
		padding: 2px 6px;  
		border-radius: 4px;  
		color: #c7254e;
	}
	
</style>

