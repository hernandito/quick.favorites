						<div style="display:flex; align-items:center; gap:8px;">
						
						
						
						<span class="preview-wrapper">
                            <?php if (strpos($data['icon'], '/') !== false || strpos($data['icon'], '.') !== false): ?>
                                <img src="<?= htmlspecialchars($data['icon']) ?>" style="width:28px; height:28px;">
                            <?php elseif (preg_match('/^[a-zA-Z0-9\-]+$/', $data['icon'])): ?>
