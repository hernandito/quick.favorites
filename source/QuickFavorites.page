            <div style="flex: 1; display: flex; flex-direction: column; gap: 20px;">
        
				<div class="qf-guide-block">
                    <h3 style="margin-top: 0; margin-bottom: 15px;">Advanced Icon Guide</h3>
                    <p style="margin-top: 0; margin-bottom: 15px; font-size: 14px;">The auto-scanner tries to find native Unraid icons, but you have three powerful ways to customize them manually:</p>

                    <h4 style="margin-top: 0; margin-bottom: 5px; font-size: 14px;">1. Google Noto Emojis (Recommended)</h4>
                    <p style="margin-top: 0; margin-bottom: 10px; font-size: 13px; line-height: 1.5;">
                        You can use standard emojis, and the plugin will automatically upgrade them to the high-quality <strong>Google Noto Color</strong> style. This ensures consistent, premium 3D-style icons across all devices (Windows, Mac, iOS, Android).
                    </p>
                    <ul style="margin-top: 0px; list-style-type: disc; padding-left: 20px; font-size: 13px; line-height: 1.5; margin-bottom: 15px;">
                        <li style="margin-bottom: 6px;"><strong>Quick Pick:</strong> Press <code>Win + .</code> (Windows) or <code>Cmd + Ctrl + Space</code> (Mac) to open your OS emoji keyboard and insert directly.</li>
                        <li><strong>Browse online:</strong> Visit <a href="https://emojiterra.com/" target="_blank" style="color: #4da6ff; text-decoration: none;">emojiterra.com</a> to browse icons. You will see how the emoji looks on different platforms (Apple, Google, etc.). Simply click "Copy" on the raw Unicode character and paste it here. <br><em>Note: Even if it temporarily looks like the standard Windows/Mac flat emoji when you paste it into the box, the plugin will automatically transform it into the beautiful Google version in the live preview and final menu!</em></li>
                    </ul>

                    <h4 style="margin-top: 0; margin-bottom: 5px; font-size: 14px;">2. FontAwesome & Custom Images</h4>
                    <ul style="margin-top: 0px; list-style-type: disc; padding-left: 20px; font-size: 13px; line-height: 1.5; margin-bottom: 0;">
                        <li style="margin-bottom: 5px;"><strong>FontAwesome:</strong> Type any FA class (e.g., <code>fa-desktop</code>).</li>
                        <li style="margin-bottom: 5px;"><strong>Images:</strong> Paste the full path to a PNG/SVG (e.g., <code>/plugins/name/icon.png</code>).</li>
                        <li><strong>Inspect Element:</strong> You can right-click any native Unraid header icon, click <strong>Inspect</strong>, and copy either its <code>fa-</code> class or image <code>src</code> path.</li>
                    </ul>
                </div>



                <div style="display: flex; flex-direction: column; flex-grow: 1;">
                    <h3 style="margin-top: 0; margin-bottom: 5px; font-size: 16px;">User Notes</h3>
                    <textarea name="user_notes" class="qf-notes-area" style="resize: none; font-size: 12px;" placeholder="Save snippets or script arguments..."><?= htmlspecialchars($saved_notes) ?></textarea>
                </div>
            </div>

        </div>
    </form>



<script>


$(function() {
    // 1. Drag and Drop Sorting
    if (typeof $.fn.sortable !== 'undefined') {
        $("#fav-table-body").sortable({
            handle: '.drag-handle',
            cursor: 'grabbing',
            axis: 'y',
            opacity: 0.8
        });
    }

    // 2. Bulletproof Hybrid Color Picker Sync
    // When the color box changes...
    $(document).on('input change', '.color-picker-sync', function() {
        var hex = $(this).val().toUpperCase();
        $(this).siblings('.color-text-sync').val(hex);
    });
    
    // When the text box changes...
    $(document).on('input keyup', '.color-text-sync', function() {
        var hex = $(this).val().trim();
        
        // Auto-add the # if the user forgets it
        if (hex.length > 0 && hex.charAt(0) !== '#') {
            hex = '#' + hex;
        }
        
        // Standard HTML color inputs require exactly 6 valid characters (plus the #)
        if(/^#[0-9A-F]{6}$/i.test(hex)) {
            $(this).siblings('.color-picker-sync').val(hex);
        }
    });
});

// 3. Table Functions (Preview & Fetch Icon)
function updatePreview(inputElement) {
    var val = $(inputElement).val().trim();
    var wrapper = $(inputElement).siblings('.preview-wrapper');
    
    // 1. Default (Star)
    if (val === '') {
        wrapper.html('<i class="fa fa-star" style="width:28px; text-align:center; font-size:24px;"></i>');
        return;
    }
    
    // 2. Images & URLs
    if (val.includes('/') || val.includes('.')) {
        wrapper.html('<img src="' + val + '" style="width:28px; height:28px; object-fit:contain;">');
        return;
    }
    
    // 3. Native Unraid FontAwesome 4 Format
    if (/^[a-zA-Z0-9\-\s]+$/.test(val)) {
        var cleanName = val.trim();
        
        // Strip off "fa-" if the user typed it
        if (cleanName.startsWith('fa-')) {
            cleanName = cleanName.substring(3);
        }
        
        // Rebuild perfectly for Unraid
        wrapper.html('<i class="fa fa-' + cleanName + '" style="width:28px; text-align:center; font-size:24px;"></i>');
        return;
    }
    
    // 4. Emojis
    wrapper.html('<span style="font-family: \'Noto Color Emoji\', sans-serif; font-size: 24px; line-height: 28px; display: inline-block; width: 28px; text-align: center;">' + val + '</span>');
}


function updatePreview(inputElement) {
    var val = $(inputElement).val().trim();
    var wrapper = $(inputElement).siblings('.preview-wrapper');
    
    // 1. Default (Star)
    if (val === '') {
        wrapper.html('<i class="fa fa-star" style="width:28px; text-align:center; font-size:24px;"></i>');
        return;
    }
    
    // 2. Images & URLs
    if (val.includes('/') || val.includes('.')) {
        wrapper.html('<img src="' + val + '" style="width:28px; height:28px; object-fit:contain;">');
        return;
    }
    
    // 3. Native Unraid FontAwesome 4 Format
    if (/^[a-zA-Z0-9\-\s]+$/.test(val)) {
        var cleanName = val.trim();
        
        // If the user typed "fa-" at the beginning, strip it off temporarily
        if (cleanName.startsWith('fa-')) {
            cleanName = cleanName.substring(3);
        }
        
        // Rebuild it to exactly match the Unraid core HTML you just inspected
        wrapper.html('<i class="fa fa-' + cleanName + '" style="width:28px; text-align:center; font-size:24px;"></i>');
        return;
    }
    
    // 4. Emojis
    wrapper.html('<span style="font-family: \'Noto Color Emoji\', sans-serif; font-size: 24px; line-height: 28px; display: inline-block; width: 28px; text-align: center;">' + val + '</span>');
}


function addRow() {
    var newRow = `<tr class="qf-row">
        <td class="drag-handle" title="Drag to reorder"><i class="fa fa-bars"></i></td>
        <td style="max-width: 140px;"><input type="text" name="category[]" placeholder="Category" required class="qf-input"></td>
        <td style="max-width: 140px;"><input type="text" name="label[]" placeholder="Label" required class="qf-input"></td>
        <td><input type="text" name="path[]" placeholder="Folder or URL" required class="qf-input path-input"></td>
        <td>
            <div style="display:flex; align-items:center; gap:8px;">
                <span class="preview-wrapper"><i class="fa fa-star"></i></span>
                <input type="text" name="icon[]" placeholder="fa-star" required class="qf-input" oninput="updatePreview(this)">
            </div>
        </td>
        <td>
		
			<select name="action_type[]" class="qf-input">
                <option value="_self">Same Tab</option>
                <option value="_blank">New Tab</option>
                <option value="script_modal">Run Script (Console)</option>
                <option value="script_background">Run Background</option>
                <option value="script_log">User Script Log</option>
            </select>

			
			
        </td>
        <td class="qf-row-right-end" style="text-align:center;">
            <button type="button" class="qf-btn-remove" onclick="$(this).closest('tr').remove();"><i class="fa fa-times"></i></button>
        </td>
    </tr>`;

$('#fav-table-body').append(newRow);
}

// 4. Appearance Backup & Reset Functions
function copyAppearanceSettings() {
    var text = "--- Theme Backup ---\n";
    text += "Header Title: " + $('input[name="menu_title"]').val() + "\n";
    text += "Icon Size: " + $('input[name="icon_size"]').val() + "px\n";
    text += "Grid Columns: " + $('input[name="grid_columns"]').val() + "\n";
    text += "Menu Width: " + $('input[name="menu_width"]').val() + "px\n";
    text += "Show Header: " + $('select[name="show_header"]').val() + "\n";
    text += "Menu BG: " + $('input[name="bg_color"]').val() + "\n";
    text += "Hover BG: " + $('input[name="hover_color"]').val() + "\n";
    text += "Header Font: " + $('input[name="header_color"]').val() + "\n";
    text += "Header Line: " + $('input[name="header_line"]').val() + "\n";
    text += "Section Font: " + $('input[name="section_title_color"]').val() + "\n";
    text += "Section Line: " + $('input[name="section_border_color"]').val() + "\n";
    text += "Icon (FA): " + $('input[name="icon_color"]').val() + "\n";
    text += "Label Font: " + $('input[name="label_color"]').val();

    // Fallback method for local HTTP Unraid connections
    var tempTextArea = document.createElement("textarea");
    tempTextArea.value = text;
    // Move it off-screen so it doesn't cause a layout jump
    tempTextArea.style.position = "absolute";
    tempTextArea.style.left = "-9999px";
    document.body.appendChild(tempTextArea);
    tempTextArea.select();
    tempTextArea.setSelectionRange(0, 99999); // For mobile compatibility

    try {
        document.execCommand("copy");
        var btn = $('#btn-copy-app');
        var originalText = btn.html();
        btn.html('✅ Copied!');
        btn.css('background', 'rgba(0, 255, 0, 0.1)');
        setTimeout(function() { 
            btn.html(originalText); 
            btn.css('background', 'rgba(255,255,255,0.08)');
        }, 2000);
    } catch (err) {
        alert("Clipboard copy failed. Your browser may be blocking it.");
    }

    // Clean up the invisible text area
    document.body.removeChild(tempTextArea);
}

function resetAppearanceDefaults() {
    swal({
        title: "Reset Appearance?",
        text: "This will reset all styling back to the default theme.\n\n(You will still need to click 'Save Settings' afterward to make it permanent.)",
        type: "warning",
        showCancelButton: true,
        confirmButtonColor: "#ff4444",
        confirmButtonText: "Yes, reset it!",
        closeOnConfirm: true
    }, function() {
        // Reset Standard Inputs
        $('input[name="menu_title"]').val('Quick Favorites');
        $('input[name="icon_size"]').val('32');
        $('input[name="grid_columns"]').val('4');
        $('input[name="menu_width"]').val('480');
        $('select[name="show_header"]').val('yes');

        // Helper function to reset both the text box and the color picker block safely
        function setCol(name, val) {
            var textInput = $('input[name="'+name+'"]');
            textInput.val(val.toUpperCase());
            textInput.siblings('.color-picker-sync').val(val);
        }

        // Reset Colors
        setCol('bg_color', '#1c1c1c');
        setCol('hover_color', '#333333');
        setCol('header_color', '#ffca28');
        setCol('header_line', '#333333');
        setCol('section_title_color', '#888888');
        setCol('section_border_color', '#333333');
        setCol('icon_color', '#e0e0e0');
        setCol('label_color', '#cccccc');
    });
}

</script>
