<?php
$cfg_dir = "/boot/config/plugins/quick.favorites";
$json_file = "$cfg_dir/favorites.json";
$css_file = "$cfg_dir/custom.css";
$notes_file = "$cfg_dir/user_notes.txt";

if (!is_dir($cfg_dir)) {
    mkdir($cfg_dir, 0755, true);
}

// 1. AJAX Listener: Unraid Core-Aware Auto-Scanner
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['action']) && $_POST['action'] === 'get_native_icon') {
    $path = trim($_POST['path'] ?? '');
    $icon = 'fa-star'; 
    
    $core_icons = [
        '/Dashboard' => 'fa-tachometer',
        '/Main' => 'fa-server',
        '/Shares' => 'fa-folder-open',
        '/Users' => 'fa-user',
        '/Settings' => 'fa-cogs',
        '/Settings/Docker' => 'fa-docker',
        '/Docker' => 'fa-docker',
        '/Plugins' => 'fa-plug',
        '/Apps' => 'fa-cubes',
        '/Settings/NetworkSettings' => 'fa-sitemap',
        '/Tools' => 'fa-wrench',
        '/VMs' => 'fa-desktop',
        '/SystemInformation' => 'fa-info-circle',
        '/Tools/Syslog' => 'fa-file-text-o'
    ];

    if (array_key_exists($path, $core_icons)) {
        $icon = $core_icons[$path];
    } elseif (!empty($path)) {
        $basename = strtolower(basename($path));
        $files = glob("/usr/local/emhttp/plugins/*/*.page");
        
        foreach ($files as $file) {
            $page_name = strtolower(basename($file, '.page'));
            if ($page_name === $basename) {
                $content = file_get_contents($file);
                if (preg_match('/Icon="([^"]+)"/i', $content, $matches)) {
                    $found = trim($matches[1]);
                    if (strpos($found, '/') !== false) {
                        $icon = $found;
                    } elseif (strpos($found, '.') !== false) {
                        $plugin_dir = basename(dirname($file));
                        $icon = "/plugins/" . $plugin_dir . "/images/" . $found;
                    } else {
                        $icon = (strpos(strtolower($found), 'fa-') === 0) ? strtolower($found) : "fa-" . strtolower($found);
                    }
                    break;
                }
            }
        }
    }
    echo $icon;
    exit;
}



// 1.5 AJAX Listener: Safe Log Reader (Bypasses Bash spaces)
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['action']) && $_POST['action'] === 'get_script_log') {
    // WIPE OUT any Unraid headers, menus, or HTML that were buffered before this script ran!
    while (ob_get_level()) { ob_end_clean(); }
    
    $path = trim($_POST['path'] ?? '');
    $path = preg_replace('/[^a-zA-Z0-9 \-_]/', '', $path);
    $logFile = "/tmp/user.scripts/tmpScripts/" . $path . "/log.txt";
    
    if (file_exists($logFile)) {
        echo file_get_contents($logFile);
    } else {
        echo "<span style='color:#ff4444; font-weight:bold;'>Log file not found. The script has not been run in the background yet, or the log was cleared.</span>";
    }
    exit;
}


// 2. Handle Save
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['save_favs'])) {
    $new_favs = [];
    $categories = $_POST['category'] ?? [];
    $labels = $_POST['label'] ?? [];
    $paths = $_POST['path'] ?? [];
    $icons = $_POST['icon'] ?? [];
    $actions = $_POST['action_type'] ?? [];
    
    for ($i = 0; $i < count($paths); $i++) {
        $cat = trim($categories[$i]);
        $l = trim($labels[$i]);
        $p = trim($paths[$i]);
        $ic = trim($icons[$i]);
        $act = trim($actions[$i]);
        
        if ($ic === '' || strpos($ic, 'spin') !== false) $ic = 'fa-star';
        if ($cat === '') $cat = 'Uncategorized';
        
        if ($p !== '' && $l !== '') {
            $new_favs[$p] = [
                'category' => $cat,
                'label' => $l,
                'icon' => $ic,
                'action' => $act
            ];
        }
    }
    
    file_put_contents($json_file, json_encode($new_favs, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES));
    
    $custom_css = $_POST['custom_css'] ?? '';
    file_put_contents($css_file, $custom_css);

    $user_notes = $_POST['user_notes'] ?? '';
    file_put_contents($notes_file, $user_notes);
	
	// Save Appearance Settings
    $appearance_data = [
        'menu_title' => $_POST['menu_title'] ?? 'Quick Favorites',
        'icon_size' => $_POST['icon_size'] ?? '42',
        'grid_columns' => $_POST['grid_columns'] ?? '4',
        'menu_width' => $_POST['menu_width'] ?? '480',
        'show_header' => $_POST['show_header'] ?? 'yes',
        'hover_color' => $_POST['hover_color'] ?? '#333333',
        'bg_color' => $_POST['bg_color'] ?? '#1c1c1c',
        'header_color' => $_POST['header_color'] ?? '#ffca28',
        'header_line' => $_POST['header_line'] ?? '#333333',
        'section_title_color' => $_POST['section_title_color'] ?? '#aaaaaa',
        'section_border_color' => $_POST['section_border_color'] ?? '#333333',
        'icon_color' => $_POST['icon_color'] ?? '#e0e0e0',
        'label_color' => $_POST['label_color'] ?? '#cccccc'
    ];
	
	
	
    file_put_contents("$cfg_dir/appearance.json", json_encode($appearance_data, JSON_PRETTY_PRINT));

    echo "<script>$(function() { swal({title:'Saved', text:'Settings updated!', type:'success', confirmButtonText:'Ok'}, function(){ window.location.href = window.location.pathname; }); });</script>";
}

// 3. Load Existing Configuration
$favs = [];
if (file_exists($json_file)) {
    $raw = json_decode(file_get_contents($json_file), true);
    if (is_array($raw)) {
        foreach ($raw as $p => $data) {
            if (is_string($data)) {
                $favs[$p] = ['category' => 'General', 'label' => $data, 'icon' => 'fa-star', 'action' => '_self'];
            } else {
                $favs[$p] = array_merge(['category' => 'General', 'action' => '_self'], $data);
            }
        }
    }
}

// Load Appearance Settings (with defaults)
$appearance_file = "$cfg_dir/appearance.json";

$defaults = [
    'menu_title' => 'Quick Favorites',
    'icon_size' => '32',
    'bg_color' => '#1c1c1c',
    'header_color' => '#ffca28',
    'header_line' => '#333333',
    'section_title_color' => '#888888',
    'text_color' => '#e0e0e0',
    'grid_columns' => '4',
    'menu_width' => '480',
    'hover_color' => '#333333',
    'show_header' => 'yes'
];


$style = file_exists($appearance_file) ? array_merge($defaults, json_decode(file_get_contents($appearance_file), true)) : $defaults;

$saved_css = file_exists($css_file) ? file_get_contents($css_file) : '';
$saved_notes = file_exists($notes_file) ? file_get_contents($notes_file) : '';
